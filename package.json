{
  "name": "ai-cofounder",
  "version": "1.0.0",
  "private": true,
  "description": "Localhost AI Co-Founder — wraps your own Claude Code in a friendly browser UI: a setup wizard that installs Claude Code, fixes PATH, installs business-coaching skills, and logs you in via browser OAuth, plus an embedded terminal session.",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "dev": "concurrently -k -n SERVER,WEB -c blue,green \"node server/index.js\" \"vite\"",
    "server": "node server/index.js",
    "build": "vite build",
    "start": "node server/index.js --open",
    "preview": "vite preview"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^5.4.11"
  }
}
